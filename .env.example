HOST=0.0.0.0
PORT=8001
DEBUG=false
APP_URL=https://wfh.example.com

# French public holidays (fetched from data.gouv.fr on startup)
FRENCHDAYOFF=false

# SMTP (leave SMTP_HOST empty to disable email notifications)
EMAIL_DELAY=900
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=wfh@example.com
SMTP_PASSWORD=
SMTP_FROM=wfh@example.com

# User 1 (man, blue)
USER1_ID=julien
USER1_USERNAME=julien
USER1_NAME=Julien

# User 2 (woman, pink)
USER2_ID=mallorie
USER2_USERNAME=mallorie
USER2_NAME=Mallorie
